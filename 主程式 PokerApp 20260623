//=============================================================================
// 基本資料結構
//=============================================================================
struct Suit {
    const wchar_t* symbol;
    const wchar_t* name;
    COLORREF color;
};

struct CardValue {
    const wchar_t* label;
    int value;
};

struct PipPos {
    int dx;
    int dy;
};

//=============================================================================
// 文字繪製工具類別
//=============================================================================
class TextRenderer {
public:
    static void Draw(
        HDC hdc,
        int x, int y,
        const std::wstring& text,
        int fontSize,
        COLORREF color,
        UINT textAlign,
        int angle10 = 0,
        const wchar_t* fontName = L"Segoe UI Symbol",
        int fontWeight = FW_NORMAL)
    {
        LOGFONTW lf = {};
        lf.lfHeight = -fontSize;
        lf.lfEscapement = angle10;
        lf.lfOrientation = angle10;
        lf.lfWeight = fontWeight;
        lf.lfCharSet = DEFAULT_CHARSET;
        lstrcpyW(lf.lfFaceName, fontName);

        HFONT hFont = CreateFontIndirectW(&lf);
        HFONT hOldFont = (HFONT)SelectObject(hdc, hFont);

        COLORREF oldColor = SetTextColor(hdc, color);
        int oldBkMode = SetBkMode(hdc, TRANSPARENT);
        UINT oldAlign = SetTextAlign(hdc, textAlign);

        TextOutW(hdc, x, y, text.c_str(), static_cast<int>(text.length()));

        SetTextAlign(hdc, oldAlign);
        SetBkMode(hdc, oldBkMode);
        SetTextColor(hdc, oldColor);
        SelectObject(hdc, hOldFont);
        DeleteObject(hFont);
    }
};

//=============================================================================
// 點數牌花色位置配置
//=============================================================================
class PipLayout {
public:
    static std::vector<PipPos> GetPositions(int count) {
        int top = -55;
        int bottom = 55;
        int v31 = top / 2;
        int v32 = -v31;
        int v41 = top / 3;
        int v42 = -v41;
        int v51 = (top + v41) / 2;
        int v52 = -v51;
        int mid = 0;
        int cen = 0;
        int left = -25;
        int right = 25;

        std::vector<std::vector<PipPos>> positions(11);
        positions[1] = { {cen, mid} };
        positions[2] = { {cen, top}, {cen, bottom} };
        positions[3] = { {cen, top}, {cen, mid}, {cen, bottom} };
        positions[4] = { {left, top}, {right, top}, {left, bottom}, {right, bottom} };
        positions[5] = { {left, top}, {right, top}, {cen, mid}, {left, bottom}, {right, bottom} };
        positions[6] = { {left, top}, {right, top}, {left, mid}, {right, mid}, {left, bottom}, {right, bottom} };
        positions[7] = { {left, top}, {right, top}, {left, mid}, {right, mid}, {cen, v31}, {left, bottom}, {right, bottom} };
        positions[8] = { {left, top}, {right, top}, {cen, v31}, {left, mid}, {right, mid}, {cen, v32}, {left, bottom}, {right, bottom} };
        positions[9] = { {left, top}, {right, top}, {cen, v51}, {left, v41}, {right, v41}, {left, v42}, {right, v42}, {left, bottom}, {right, bottom} };
        positions[10] = { {left, top}, {right, top}, {cen, v51}, {left, v41}, {right, v41}, {left, v42}, {right, v42}, {cen, v52}, {left, bottom}, {right, bottom} };

        if (count < 1 || count > 10) return {};
        return positions[count];
    }
};

//=============================================================================
// 單張牌類別
//=============================================================================
class Card {
private:
    Suit suit_;
    CardValue value_;

    static constexpr int WIDTH = 120;
    static constexpr int HEIGHT = 180;
    static constexpr int PADDING = 10;

public:
    Card(const CardValue& value, const Suit& suit)
        : suit_(suit), value_(value) {
    }

    void Draw(HDC hdc, int left, int top) const {
        DrawCardFrame(hdc, left, top);

        int innerLeft = left + PADDING;
        int innerTop = top + PADDING;
        int innerW = WIDTH - 2 * PADDING;
        int innerH = HEIGHT - 2 * PADDING;
        int innerCx = innerLeft + innerW / 2;
        int innerCy = innerTop + innerH / 2;

        DrawTopLeftCorner(hdc, innerLeft, innerTop);
        DrawBottomRightCorner(hdc, left, top);

        if (value_.value >= 1 && value_.value <= 10) {
            DrawPips(hdc, value_.value, innerCx, innerCy);
        }
        else {
            DrawFaceCard(hdc, innerCx, innerCy);
        }
    }

    static int GetWidth() { return WIDTH; }
    static int GetHeight() { return HEIGHT; }

private:
    void DrawCardFrame(HDC hdc, int left, int top) const {
        HBRUSH hWhite = CreateSolidBrush(RGB(255, 255, 255));
        HBRUSH hOldBrush = (HBRUSH)SelectObject(hdc, hWhite);

        HPEN hPen = CreatePen(PS_SOLID, 1, RGB(0, 0, 0));
        HPEN hOldPen = (HPEN)SelectObject(hdc, hPen);

        RoundRect(hdc, left, top, left + WIDTH, top + HEIGHT, 10, 10);

        SelectObject(hdc, hOldBrush);
        SelectObject(hdc, hOldPen);
        DeleteObject(hWhite);
        DeleteObject(hPen);
    }

    void DrawTopLeftCorner(HDC hdc, int innerLeft, int innerTop) const {
        TextRenderer::Draw(hdc, innerLeft, innerTop + 16, value_.label, 16,
            suit_.color, TA_LEFT | TA_BASELINE, 0, L"Segoe UI", FW_NORMAL);

        TextRenderer::Draw(hdc, innerLeft, innerTop + 32, suit_.symbol, 16,
            suit_.color, TA_LEFT | TA_BASELINE, 0, L"Segoe UI Symbol", FW_NORMAL);
    }

    void DrawBottomRightCorner(HDC hdc, int left, int top) const {
        TextRenderer::Draw(hdc, left + WIDTH - PADDING * 2, top + HEIGHT - PADDING * 2 - 16,
            suit_.symbol, 16, suit_.color, TA_RIGHT | TA_BASELINE, 1800, L"Segoe UI Symbol", FW_NORMAL);

        TextRenderer::Draw(hdc, left + WIDTH - PADDING * 2, top + HEIGHT - PADDING * 2,
            value_.label, 16, suit_.color, TA_RIGHT | TA_BASELINE, 1800, L"Segoe UI", FW_NORMAL);
    }

    void DrawPips(HDC hdc, int count, int cx, int cy) const {
        auto positions = PipLayout::GetPositions(count);

        for (const auto& p : positions) {
            int x = cx + p.dx;
            int y = cy + p.dy;

            if (p.dy < 5) {
                TextRenderer::Draw(hdc, x, y, suit_.symbol, 24, suit_.color,
                    TA_CENTER | TA_BASELINE, 0, L"Segoe UI Symbol", FW_NORMAL);
            }
            else {
                TextRenderer::Draw(hdc, x, y, suit_.symbol, 24, suit_.color,
                    TA_CENTER | TA_BASELINE, 1800, L"Segoe UI Symbol", FW_NORMAL);
            }
        }
    }

    void DrawFaceCard(HDC hdc, int cx, int cy) const {
        TextRenderer::Draw(hdc, cx, cy + 14, value_.label, 40, suit_.color,
            TA_CENTER | TA_BASELINE, 0, L"Segoe UI", FW_BOLD);
    }
};

//=============================================================================
// 主視窗 App 類別
//=============================================================================
class PokerWindowApp : public IPokerApp {

private:
    HINSTANCE hInctance_;
    HWND hwnd_;
    HMODULE hDll_; // 用來儲存載入的 DLL 參考
    // ... 其他變數 ...

    int currentSuitIndex_ = 0;
    int currentValueIndex_ = 0;

    int currentShownSeqIndex_ = 0;
    int nextSeqIndex_ = 0;

    bool running_ = false;
    bool hasCurrentItem_ = false;
    bool isDoubleMode_ = false;    // 區分單人或雙人模式
    int countdownValue_ = 0;       // 321倒數數值 (0代表倒數結束)

    ULONGLONG shownTick_ = 0;
    std::mt19937 rng_;

    std::vector<int> deckOrder_;
    size_t deckPos_ = 0;

    bool anyMatchOccurred_ = false;

    static constexpr const wchar_t* CLASS_NAME = L"PokerCardWin32MenuReaction";
    static constexpr UINT TIMER_ID = 1001;

    // 與截圖完全一致的平鋪選單 ID
    static constexpr UINT ID_MENU_START_SINGLE = 40001;
    static constexpr UINT ID_MENU_START_DOUBLE = 40002;
    static constexpr UINT ID_MENU_STOP = 40003;
    static constexpr UINT ID_MENU_EXIT = 40004;
    static constexpr UINT ID_HELP_ABOUT = 10005;

    // 快捷鍵 ID
    static constexpr int HOTKEY_ID_SPACE = 50001;
    static constexpr int HOTKEY_ID_PLAYER_A = 50002;
    static constexpr int HOTKEY_ID_PLAYER_L = 50003;

public:
    explicit PokerWindowApp(HINSTANCE hInctance)
        : hInctance_(hInctance), hwnd_(nullptr), rng_(std::random_device{}()) {
        hDll_ = LoadLibraryW(L"PokerLogicDll.dll");
        if (!hDll_) {
            // 如果 DLL 檔案找不到，彈出視窗提醒
            MessageBoxW(nullptr, L"無法找到 PokerLogicDll.dll！", L"錯誤", MB_OK | MB_ICONERROR);
        }
    }
    std::wstring GetCurrentCardLabel() override {
        return GetCardValues()[currentValueIndex_].label;
    }

    std::wstring GetCurrentSeqLabel() override {
        return GetSequenceLabels()[currentShownSeqIndex_];
    }

    bool Create(int nCmdShow) {
        WNDCLASSW wc = {};
        wc.lpfnWndProc = PokerWindowApp::WndProc;
        wc.hInstance = hInctance_;
        wc.lpszClassName = CLASS_NAME;
        wc.hCursor = LoadCursor(nullptr, IDC_ARROW);
        wc.hbrBackground = (HBRUSH)(COLOR_WINDOW + 1);

        RegisterClassW(&wc);

        hwnd_ = CreateWindowExW(
            0,
            CLASS_NAME,
            L"Win32 API 撲克牌反應測試",
            WS_OVERLAPPEDWINDOW,
            CW_USEDEFAULT, CW_USEDEFAULT,
            1000, 700,
            nullptr,
            nullptr,
            hInctance_,
            this
        );

        if (!hwnd_) return false;

        SetMenu(hwnd_, CreateAppMenu());

        ShowWindow(hwnd_, nCmdShow);
        UpdateWindow(hwnd_);
        return true;
    }

    int Run() {
        MSG msg = {};
        while (GetMessageW(&msg, nullptr, 0, 0)) {
            TranslateMessage(&msg);
            DispatchMessageW(&msg);
        }

        return static_cast<int>(msg.wParam);
    
    }

private:
    // 重新建構符合截圖畫面的頂層菜單
    HMENU CreateAppMenu() {
        HMENU hMenuBar = CreateMenu();
        AppendMenuW(hMenuBar, MF_STRING, ID_MENU_START_SINGLE, L"【單人計時賽】");
        AppendMenuW(hMenuBar, MF_STRING, ID_MENU_START_DOUBLE, L"【雙人鍵盤競速】");
        AppendMenuW(hMenuBar, MF_STRING, ID_MENU_STOP, L"停止");
        AppendMenuW(hMenuBar, MF_STRING, ID_HELP_ABOUT, L"遊戲說明");
        AppendMenuW(hMenuBar, MF_STRING, ID_MENU_EXIT, L"結束");
        return hMenuBar;
    }

    static const std::array<Suit, 4>& GetSuits() {
        static const std::array<Suit, 4> suits = {
            Suit{ L"♠", L"spade",  RGB(0, 0, 0) },
            Suit{ L"♥", L"heart",  RGB(220, 0, 0) },
            Suit{ L"♦", L"diamond",RGB(220, 0, 0) },
            Suit{ L"♣", L"club",   RGB(0, 0, 0) }
        };
        return suits;
    }

    static const std::array<CardValue, 13>& GetCardValues() {
        static const std::array<CardValue, 13> values = {
            CardValue{ L"A",  1 }, CardValue{ L"2",  2 }, CardValue{ L"3",  3 },
            CardValue{ L"4",  4 }, CardValue{ L"5",  5 }, CardValue{ L"6",  6 },
            CardValue{ L"7",  7 }, CardValue{ L"8",  8 }, CardValue{ L"9",  9 },
            CardValue{ L"10", 10 }, CardValue{ L"J",  11 }, CardValue{ L"Q",  12 },
            CardValue{ L"K",  13 }
        };
        return values;
    }

    static const std::array<const wchar_t*, 13>& GetSequenceLabels() {
        static const std::array<const wchar_t*, 13> seq = {
            L"1", L"2", L"3", L"4", L"5", L"6", L"7", L"8", L"9", L"10", L"J", L"Q", L"K"
        };
        return seq;
    }

    // 0.5 秒 到 1.5 秒之間隨機均勻分布，機率平分
    int RandomIntervalMs() {
        std::uniform_int_distribution<int> dist(500, 1500);
        return dist(rng_);
    }

    void BuildShuffledDeck() {
        deckOrder_.clear();
        deckOrder_.reserve(52);
        for (int i = 0; i < 52; ++i) {
            deckOrder_.push_back(i);
        }
        std::shuffle(deckOrder_.begin(), deckOrder_.end(), rng_);
        deckPos_ = 0;
    }

    bool IsCardAndTextMatched() const {
        const auto& values = GetCardValues();
        const auto& seq = GetSequenceLabels();

        std::wstring cardText = values[currentValueIndex_].label;
        std::wstring shownText = seq[currentShownSeqIndex_];

        if (cardText == L"A" && shownText == L"1") return true;
        return cardText == shownText;
    }

    void StartSequence(bool doubleMode) {
        StopSequence();

        isDoubleMode_ = doubleMode;
        running_ = true;
        hasCurrentItem_ = false;
        nextSeqIndex_ = 0;
        currentShownSeqIndex_ = 0;
        anyMatchOccurred_ = false;
        countdownValue_ = 3; // 設定 3 秒倒數

        BuildShuffledDeck();

        // 註冊對應模式的按鍵
        if (isDoubleMode_) {
            RegisterHotKey(hwnd_, HOTKEY_ID_PLAYER_A, 0, 'A');
            RegisterHotKey(hwnd_, HOTKEY_ID_PLAYER_L, 0, 'L');
        }
        else {
            RegisterHotKey(hwnd_, HOTKEY_ID_SPACE, 0, VK_SPACE);
        }

        // 啟動倒數定時器 (固定 1 秒跳一次)
        SetTimer(hwnd_, TIMER_ID, 1000, nullptr);
        InvalidateRect(hwnd_, nullptr, TRUE);
    }

    void StopSequence() {
        KillTimer(hwnd_, TIMER_ID);
        UnregisterHotKey(hwnd_, HOTKEY_ID_SPACE);
        UnregisterHotKey(hwnd_, HOTKEY_ID_PLAYER_A);
        UnregisterHotKey(hwnd_, HOTKEY_ID_PLAYER_L);
        running_ = false;
        hasCurrentItem_ = false;
        countdownValue_ = 0;
        InvalidateRect(hwnd_, nullptr, TRUE);
    }

    void ScheduleNextTimer() {
        KillTimer(hwnd_, TIMER_ID);
        SetTimer(hwnd_, TIMER_ID, RandomIntervalMs(), nullptr);
    }

    bool ShowNextItem() {
        if (deckPos_ >= deckOrder_.size()) return false;

        int cardId = deckOrder_[deckPos_++];
        currentSuitIndex_ = cardId / 13;
        currentValueIndex_ = cardId % 13;

        currentShownSeqIndex_ = nextSeqIndex_;
        nextSeqIndex_ = (nextSeqIndex_ + 1) % 13;

        shownTick_ = GetTickCount64();
        hasCurrentItem_ = true;

        if (IsCardAndTextMatched()) {
            anyMatchOccurred_ = true;
        }

        InvalidateRect(hwnd_, nullptr, TRUE);
        return true;
    }

    void ShowNoMatchFailureIfNeeded() {
        StopSequence();
        MessageBoxW(hwnd_, L"52 張牌全部發完！遊戲結束。", L"提示", MB_OK | MB_ICONINFORMATION);
    }

    void HandleSpacePressed() {
        if (!running_ || !hasCurrentItem_ || countdownValue_ > 0) return;

        ULONGLONG now = GetTickCount64();
        ULONGLONG elapsed = now - shownTick_;
        bool correct = IsCardAndTextMatched();

        StopSequence();

        std::wstringstream ss;
        ss << L"撲克牌：" << GetCardValues()[currentValueIndex_].label << L"\n"
            << L"右邊數字：" << GetSequenceLabels()[currentShownSeqIndex_] << L"\n"
            << L"結果：" << (correct ? L"答對" : L"失敗") << L"\n"
            << L"反應時間：" << elapsed << L" 毫秒";

        MessageBoxW(hwnd_, ss.str().c_str(), correct ? L"答對" : L"失敗", MB_OK | (correct ? MB_ICONINFORMATION : MB_ICONWARNING));
    }

    void HandleDoublePlayerPressed(wchar_t player) {
        if (!running_ || !hasCurrentItem_ || countdownValue_ > 0) return;

        ULONGLONG now = GetTickCount64();
        ULONGLONG elapsed = now - shownTick_;
        bool isCorrect = IsCardAndTextMatched();

        StopSequence();

        std::wstringstream ss;
        std::wstring resultTitle = L"結果：玩家" + std::wstring(1, player) + (isCorrect ? L"贏" : L"輸");

        ss << L"玩家 " << player << (isCorrect ? L" 贏了！" : L" 輸了！(錯誤搶答)") << L"\n"
            << L"反應時間：" << elapsed << L" 毫秒\n"
            << L"目前卡牌：" << GetCardValues()[currentValueIndex_].label << L"\n"
            << L"目標數字：" << GetSequenceLabels()[currentShownSeqIndex_];

        MessageBoxW(hwnd_, ss.str().c_str(), resultTitle.c_str(), MB_OK | (isCorrect ? MB_ICONINFORMATION : MB_ICONWARNING));
    }

    void OnPaint() {
        PAINTSTRUCT ps;
        HDC hdc = BeginPaint(hwnd_, &ps);

        RECT rc;
        GetClientRect(hwnd_, &rc);

        HBRUSH bg = CreateSolidBrush(RGB(255, 255, 255));
        FillRect(hdc, &rc, bg);
        DeleteObject(bg);

        int centerX = (rc.left + rc.right) / 2;
        int centerY = (rc.top + rc.bottom) / 2 + 20;

        // 狀態 1：正在進行 3 2 1 倒數
        if (running_ && countdownValue_ > 0) {
            std::wstringstream ss;
            ss << countdownValue_;
            TextRenderer::Draw(hdc, centerX, centerY, ss.str(), 120, RGB(230, 40, 40), TA_CENTER | TA_BASELINE, 0, L"Segoe UI", FW_BOLD);
            TextRenderer::Draw(hdc, centerX, centerY + 60, L"遊戲即將開始，請準備...", 24, RGB(120, 120, 120), TA_CENTER | TA_BASELINE, 0, L"Microsoft JhengHei UI", FW_NORMAL);
        }
        // 狀態 2：倒數完畢，遊戲正式進行中且有牌面
        else if (hasCurrentItem_) {
            const auto& suits = GetSuits();
            const auto& values = GetCardValues();
            const auto& seq = GetSequenceLabels();

            Card card(values[currentValueIndex_], suits[currentSuitIndex_]);
            int cardW = Card::GetWidth();
            int cardH = Card::GetHeight();
            int cardLeft = centerX - cardW / 2;
            int cardTop = centerY - cardH / 2;

            card.Draw(hdc, cardLeft, cardTop);

            // 右邊目標大數字
            TextRenderer::Draw(hdc, cardLeft + cardW + 100, centerY + 20, seq[currentShownSeqIndex_], 64, RGB(0, 90, 180), TA_CENTER | TA_BASELINE, 0, L"Segoe UI", FW_BOLD);

            // 頂部提示與模式狀態
            if (isDoubleMode_) {
                TextRenderer::Draw(hdc, 50, 50, L"【玩家 A】— 請按 A 鍵", 24, RGB(200, 0, 0), TA_LEFT | TA_TOP, 0, L"Microsoft JhengHei UI", FW_BOLD);
                TextRenderer::Draw(hdc, rc.right - 50, 50, L"【玩家 L】— 請按 L 鍵", 24, RGB(0, 150, 0), TA_RIGHT | TA_TOP, 0, L"Microsoft JhengHei UI", FW_BOLD);
                TextRenderer::Draw(hdc, centerX, 50, L"雙人鍵盤競速中...", 20, RGB(128, 128, 128), TA_CENTER | TA_TOP, 0, L"Microsoft JhengHei UI", FW_NORMAL);
            }
            else {
                TextRenderer::Draw(hdc, centerX, 50, L"單人計時賽中... (請按空白鍵反應)", 20, RGB(0, 100, 200), TA_CENTER | TA_TOP, 0, L"Microsoft JhengHei UI", FW_BOLD);
            }

            // 左下角計數進度
            std::wstringstream ss;
            ss << L"第 " << deckPos_ << L" / 52 張";
            TextRenderer::Draw(hdc, 30, rc.bottom - 30, ss.str(), 18, RGB(80, 80, 80), TA_LEFT | TA_BASELINE, 0, L"Microsoft JhengHei UI", FW_NORMAL);
        }
        // 狀態 3：初始未開局狀態 (只會有一組清晰、置中的引導文字，徹底解決舊代碼疊加重疊問題)


        EndPaint(hwnd_, &ps);
    }

    LRESULT HandleMessage(UINT msg, WPARAM wParam, LPARAM lParam) {
        switch (msg) {
        case WM_CHAR:
            if (wParam == L'Y') { // 'Y' 代表 DLL 判斷為正確
                HandleSpacePressed(); // 直接觸發跟手動按空白鍵一樣的邏輯
            }
            return 0;
        case WM_COMMAND:
            switch (LOWORD(wParam)) {
            case ID_MENU_START_SINGLE:
                StartSequence(false);
                return 0;
            case ID_MENU_START_DOUBLE:
                StartSequence(true);
                return 0;
            case ID_MENU_STOP:
                StopSequence();
                return 0;
            case ID_MENU_EXIT:
                DestroyWindow(hwnd_);
                return 0;
            case ID_HELP_ABOUT:
                MessageBoxW(hwnd_,
                    L"【單人計時賽】：按空白鍵反應。\n\n"
                    L"【雙人鍵盤競速】：\n"
                    L"1. 點選上方的「雙人鍵盤競速」。\n"
                    L"2. 畫面會先進行 3, 2, 1 倒數。\n"
                    L"3. 當中央牌面與右側數字一致時，玩家 A 搶按 'A' 鍵，玩家 L 搶按 'L' 鍵！\n"
                    L"4. 錯誤搶答直接判定為輸。\n\n"
                    L"【間隔設定】：卡牌停留時間在 0.5 秒 ~ 1.5 秒之間完全隨機均勻分布。",
                    L"遊戲說明", MB_OK | MB_ICONINFORMATION);
                return 0;
            }
            break;

        case WM_TIMER:
            if (wParam == TIMER_ID && running_) {
                // 處理開局倒數定時
                if (countdownValue_ > 1) {
                    countdownValue_--;
                    InvalidateRect(hwnd_, nullptr, TRUE);
                }
                else if (countdownValue_ == 1) {
                    countdownValue_ = 0; // 倒數結束
                    if (deckPos_ < deckOrder_.size()) {
                        ShowNextItem();
                        ScheduleNextTimer(); // 正式切換為 0.5~1.5秒 的隨機定時
                    }
                    else {
                        ShowNoMatchFailureIfNeeded();
                    }
                }
                // 常規隨機發牌定時
                else {
                    if (deckPos_ < deckOrder_.size()) {
                        ShowNextItem();
                        ScheduleNextTimer();
                    }
                    else {
                        ShowNoMatchFailureIfNeeded();
                    }
                }
            }
            return 0;

        case WM_HOTKEY:
            if (wParam == HOTKEY_ID_SPACE) HandleSpacePressed();
            else if (wParam == HOTKEY_ID_PLAYER_A) HandleDoublePlayerPressed(L'A');
            else if (wParam == HOTKEY_ID_PLAYER_L) HandleDoublePlayerPressed(L'L');
            return 0;

        case WM_PAINT:
            OnPaint();
            return 0;

        case WM_DESTROY:
            KillTimer(hwnd_, TIMER_ID);
            UnregisterHotKey(hwnd_, HOTKEY_ID_SPACE);
            UnregisterHotKey(hwnd_, HOTKEY_ID_PLAYER_A);
            UnregisterHotKey(hwnd_, HOTKEY_ID_PLAYER_L);
            PostQuitMessage(0);
            return 0;

        }
        return DefWindowProcW(hwnd_, msg, wParam, lParam);
    }

public:
    static LRESULT CALLBACK WndProc(HWND hwnd, UINT msg, WPARAM wParam, LPARAM lParam) {
        PokerWindowApp* pThis = nullptr;
        if (msg == WM_NCCREATE) {
            CREATESTRUCTW* cs = reinterpret_cast<CREATESTRUCTW*>(lParam);
            pThis = static_cast<PokerWindowApp*>(cs->lpCreateParams);
            SetWindowLongPtrW(hwnd, GWLP_USERDATA, reinterpret_cast<LONG_PTR>(pThis));
            pThis->hwnd_ = hwnd;
        }
        else {
            pThis = reinterpret_cast<PokerWindowApp*>(GetWindowLongPtrW(hwnd, GWLP_USERDATA));
        }
        if (pThis) return pThis->HandleMessage(msg, wParam, lParam);
        return DefWindowProcW(hwnd, msg, wParam, lParam);
    }
};

//=============================================================================
// WinMain 入口函式
//=============================================================================
int WINAPI wWinMain(HINSTANCE hInstance, HINSTANCE hPrevInstance, PWSTR intCmdShow, int nShowCmd) {
    PokerWindowApp app(hInstance);
    if (!app.Create(nShowCmd)) return 0;
    return app.Run();
}
